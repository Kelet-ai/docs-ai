# Use redis:// for local dev; production K8s uses rediss:// (TLS) via deployment.yaml env construction
REDIS_URL=redis://localhost:6379
# Space-separated list of llms.txt URLs (supports multiple sources)
DOCS_LLMS_URLS=https://kelet.ai/llms.txt
DOCS_AI_MODEL=bedrock:global.anthropic.claude-sonnet-4-6
RATE_LIMIT_MESSAGES_PER_WINDOW=20
RATE_LIMIT_WINDOW_SECONDS=3600
SESSION_TTL_SECONDS=1800
# Set to the proxy CIDR (or "*") when running behind a reverse proxy or load balancer
# so uvicorn resolves the real client IP from X-Forwarded-For for rate limiting.
# UVICORN_FORWARDED_ALLOW_IPS=*
